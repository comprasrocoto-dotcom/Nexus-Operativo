# URL del Web App de Google Apps Script (Implementar > Aplicacion web)
GAS_URL=
# Clave interna que Next.js envia a GAS en cada llamada (invento tuyo, larga)
GAS_API_KEY=
# Secreto para firmar los tokens de sesion (largo y aleatorio)
SESSION_HMAC_SECRET=cambia-esto-por-un-secreto-largo
# Secreto que el trigger onEdit de GAS usa para invalidar cache
REVALIDATE_SECRET=cambia-esto-tambien
